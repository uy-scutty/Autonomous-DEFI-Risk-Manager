# ─── Required ─────────────────────────────────────────────────────────────────
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
AGENT_PRIVATE_KEY=0xYOUR_AGENT_WALLET_PRIVATE_KEY

# Deployed contract addresses (from Deploy.s.sol output)
VAULT_MANAGER_ADDRESS=0x...
AGENT_REGISTRY_ADDRESS=0x...
PROTECTION_ACTIONS_ADDRESS=0x...
RISK_ORACLE_ADDRESS=0x...

# ─── Anthropic (for NL explanations) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram (optional but recommended for demo) ─────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...

# ─── Optional tuning ──────────────────────────────────────────────────────────
SCAN_CRON=*/30 * * * * *     # every 30 seconds
EVENT_REPLAY_BLOCKS=100000   # blocks to replay on startup
MAX_CONCURRENCY=10            # parallel user scans

DEFAULT_WARNING_HF=1.6
DEFAULT_ACTION_HF=1.4
DEFAULT_CRITICAL_HF=1.1
DEFAULT_MAX_REPAY_BP=2000
DEFAULT_MAX_DELG_BP=3000

GAS_BUFFER_PCT=20
MAX_GAS_PRICE_GWEI=2
SLIPPAGE_BP=50
CONFIRM_TIMEOUT_MS=60000

DB_PATH=./data/agent.db
LOG_LEVEL=info               # debug | info | warn | error

# ─── Testnet override ─────────────────────────────────────────────────────────
# ARBITRUM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
